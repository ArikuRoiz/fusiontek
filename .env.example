PORT=3000
DB_PATH=./feedback.db

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: ollama | openai | gemini  (default: ollama)
LLM_PROVIDER=ollama

# ── Ollama (local) ────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b

# ── OpenAI ────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ── Gemini ────────────────────────────────────────────────────────────────────
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-1.5-flash
