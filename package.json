{
  "name": "fusion-feedback",
  "version": "1.0.0",
  "description": "AI-assisted feedback analysis service",
  "main": "src/app.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node --watch src/app.js",
    "client": "npx serve public -p 8080",
    "dev:all": "concurrently -n api,client -c cyan,magenta \"npm run dev\" \"npm run client\"",
    "test": "node --test tests/*.test.js"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "supertest": "^7.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "express": "^4.19.2",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  }
}
